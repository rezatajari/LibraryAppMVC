@inherits LayoutComponentBase
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime

<div class="container-fluid">
    <div class="row">
        <nav class="col-md-3 col-lg-2 d-md-block bg-dark min-vh-100 text-white p-3">
            <div class="fs-4 mb-4 text-center border-bottom pb-2">
                <i class="bi bi-book-half me-2"></i> Library System
            </div>

            <ul class="nav nav-pills flex-column mb-auto ps-0">
                <li class="nav-item mb-2">
                    <NavLink class="nav-link text-white d-flex align-items-center gap-2" href="/dashboard" Match="NavLinkMatch.All">
                        <i class="bi bi-house-door"></i> Dashboard
                    </NavLink>
                </li>
                <li class="nav-item mb-2">
                    <NavLink class="nav-link text-white d-flex align-items-center gap-2" href="books">
                        <i class="bi bi-collection"></i> Books List
                    </NavLink>
                </li>
                <li class="nav-item mb-2">
                    <NavLink class="nav-link text-white d-flex align-items-center gap-2" href="users">
                        <i class="bi bi-people-fill"></i> Users Management
                    </NavLink>
                </li>
                <li class="nav-item mt-4 pt-4 border-top">
                    @if (!string.IsNullOrEmpty(userName))
                    {
                        <div class="px-3 mb-2 small text-muted">Logged in as: <br /><strong class="text-white">@userName</strong></div>
                        <button class="btn btn-sm btn-outline-danger w-100 d-flex align-items-center justify-content-center gap-2" @onclick="HandleLogout">
                            <i class="bi bi-box-arrow-right"></i> Logout
                        </button>
                    }
                    else
                    {
                        <NavLink class="nav-link text-white d-flex align-items-center gap-2" href="login">
                            <i class="bi bi-box-arrow-in-right"></i> Login / Register
                        </NavLink>
                    }
                </li>
            </ul>
        </nav>

        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 pt-4">
            <div class="card shadow-sm p-4">
                @Body
            </div>
        </main>
    </div>
</div>

@code {
    private string? userName;

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            userName = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "user_name");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error reading storage in layout: {ex.Message}");
        }
    }
    private async Task HandleLogout()
    {
        try
        {
            await Http.PostAsync("api/users/logout", null);

            await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "user_name");
            userName = null;

            Nav.NavigateTo("login");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error during logout: {ex.Message}");
        }
    }
}