@page "/books"
@using LibraryAppMVC.Shared.Models
@using System.Net.Http.Json
@inject HttpClient Http

<h3 class="mb-4">Books Management</h3>

<div class="card mb-4 shadow-sm">
    <div class="card-header bg-primary text-white">
        <h5 class="card-title mb-0"><i class="bi bi-plus-circle me-2"></i>Add New Book</h5>
    </div>
    <div class="card-body">
        <EditForm Model="@newBook" OnValidSubmit="HandleCreateBook">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Book Title</label>
                    <input type="text" class="form-control" @bind-value="newBook.Title" placeholder="e.g. Clean Code" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Author</label>
                    <input type="text" class="form-control" @bind-value="newBook.Author" placeholder="e.g. Robert C. Martin" required />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Year Published</label>
                    <input type="number" class="form-control" @bind-value="newBook.YearPublished" required />
                </div>
                <h5 class="card-title mb-0">
                    <i class="bi @(isEditMode ? "bi-pencil-square" : "bi-plus-circle") me-2"></i>
                    @(isEditMode ? "Edit Book Details" : "Add New Book")
                </h5>

                <button type="submit" class="btn @(isEditMode ? "btn-warning" : "btn-success") w-100">
                    <i class="bi @(isEditMode ? "bi-arrow-clockwise" : "bi-check-lg") me-1"></i>
                    @(isEditMode ? "Update" : "Save Book")
                </button>
            </div>
        </EditForm>
    </div>
</div>

@if (books == null)
{
    <p><em>Loading books...</em></p>
}
else if (!books.Any())
{
    <div class="alert alert-info">No books registered in the library yet.</div>
}
else
{
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Author</th>
                <th>Year Published</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in books)
            {
                <tr>
                    <td>@book.Id</td>
                    <td>@book.Title</td>
                    <td>@book.Author</td>
                    <td>@book.YearPublished</td>
                    <td>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-warning" @onclick="() => PrepareEdit(book)">
                                <i class="bi bi-pencil-square"></i> Edit
                            </button>

                            <button class="btn btn-sm btn-danger" @onclick="() => HandleDeleteBook(book.Id)">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Book>? books;
    private Book newBook = new();
    private bool isEditMode = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadBooks();
    }

    private async Task LoadBooks()
    {
        try
        {
            books = await Http.GetFromJsonAsync<List<Book>>("api/books");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching data: {ex.Message}");
        }
    }

    private async Task HandleCreateBook()
    {
        try
        {
            if (isEditMode)
            {
                var response = await Http.PutAsJsonAsync($"api/books/{newBook.Id}", newBook);
                if (response.IsSuccessStatusCode)
                {
                    isEditMode = false;
                }
            }
            else
            {
                await Http.PostAsJsonAsync("api/books", newBook);
            }

            newBook = new Book();
            await LoadBooks();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error processing book: {ex.Message}");
        }
    }

    private void PrepareEdit(Book book)
    {
        newBook = new Book
        {
            Id = book.Id,
            Title = book.Title,
            Author = book.Author,
            YearPublished = book.YearPublished
        };
        isEditMode = true;
    }

    private async Task HandleDeleteBook(int id)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/books/{id}");

            if (response.IsSuccessStatusCode)
            {
                if (newBook.Id == id)
                {
                    newBook = new Book();
                    isEditMode = false;
                }

                await LoadBooks();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting book: {ex.Message}");
        }
    }
}