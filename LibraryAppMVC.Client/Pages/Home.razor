@page "/"
@using LibraryAppMVC.Shared.Models
@inject HttpClient Http

<PageTitle>Dashboard - Library System</PageTitle>

<h3 class="mb-4">Dashboard</h3>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card bg-primary text-white h-100 shadow-sm">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="text-uppercase mb-1" style="font-size: 0.8rem; opacity: 0.8;">Total Books</h6>
                    <h2 class="mb-0 fw-bold">@(books?.Count ?? 0)</h2>
                </div>
                <i class="bi bi-bookshelf fs-1" style="opacity: 0.3;"></i>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card bg-success text-white h-100 shadow-sm">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="text-uppercase mb-1" style="font-size: 0.8rem; opacity: 0.8;">Latest Publication</h6>
                    <h2 class="mb-0 fw-bold">@(books?.Any() == true ? books.Max(b => b.YearPublished) : "-")</h2>
                </div>
                <i class="bi bi-calendar-check fs-1" style="opacity: 0.3;"></i>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card bg-info text-white h-100 shadow-sm">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="text-uppercase mb-1" style="font-size: 0.8rem; opacity: 0.8;">System Status</h6>
                    <h2 class="mb-0 fw-bold" style="font-size: 1.5rem;">Online</h2>
                </div>
                <i class="bi bi-cpu fs-1" style="opacity: 0.3;"></i>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-light">
        <h5 class="card-title mb-0"><i class="bi bi-clock-history me-2"></i>Recently Added Books</h5>
    </div>
    <div class="card-body p-0">
        @if (books == null)
        {
            <div class="p-3"><em>Loading dashboard data...</em></div>
        }
        else if (!books.Any())
        {
            <div class="p-3 text-muted">No books available to display.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>Author</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var book in books.Take(3)) // فقط ۳ تا از آخرین کتاب‌ها رو نشون میده
                        {
                            <tr>
                                <td class="fw-semibold">@book.Title</td>
                                <td class="text-muted">@book.Author</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>


@code {
    private List<Book>? books;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            books = await Http.GetFromJsonAsync<List<Book>>("api/books");

            if (books != null)
            {
                books.Reverse();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Dashboard loading error: {ex.Message}");
        }
    }
}