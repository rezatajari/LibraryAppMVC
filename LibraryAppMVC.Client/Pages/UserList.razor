@page "/users"
@attribute [Authorize]
@using LibraryAppMVC.Shared.Models
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http

<h3 class="mb-4">Users Management</h3>

<div class="card mb-4 shadow-sm">
    <div class="card-header bg-primary text-white">
        <h5 class="card-title mb-0"><i class="bi bi-person-plus-fill me-2"></i>Register New Member</h5>
    </div>
    <div class="card-body">
        <EditForm Model="@newUser" OnValidSubmit="HandleCreateUser">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger small mb-3" />

            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Full Name</label>
                    <input type="text" class="form-control" @bind-value="newUser.FullName" placeholder="e.g. John Doe" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Email Address</label>
                    <input type="email" class="form-control" @bind-value="newUser.Email" placeholder="e.g. john@example.com" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Phone Number</label>
                    <input type="text" class="form-control" @bind-value="newUser.PhoneNumber" placeholder="e.g. 0912..." />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-success w-100">
                        <i class="bi bi-person-check-fill me-1"></i>Save User
                    </button>
                </div>
            </div>
        </EditForm>
    </div>
</div>

@if (users == null)
{
    <p><em>Loading users...</em></p>
}
else if (!users.Any())
{
    <div class="alert alert-info">No users registered in the library yet.</div>
}
else
{
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Full Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Joined Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in users)
            {
                <tr>
                    <td>@user.Id</td>
                    <td class="fw-semibold">@user.FullName</td>
                    <td>@user.Email</td>
                    <td>@(user.PhoneNumber ?? "-")</td>
                    <td>@user.MembershipDate.ToShortDateString()</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<User>? users;
    private User newUser = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        try
        {
            users = await Http.GetFromJsonAsync<List<User>>("api/users");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching users: {ex.Message}");
        }
    }

    private async Task HandleCreateUser()
    {
        try
        {
            var response = await Http.PostAsJsonAsync("api/users", newUser);

            if (response.IsSuccessStatusCode)
            {
                newUser = new User();
                await LoadUsers();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating user: {ex.Message}");
        }
    }
}